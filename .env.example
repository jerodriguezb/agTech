# FieldData.ag - Configuración del Cliente Supabase
# Renombrar a .env y completar con las credenciales de tu proyecto

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY="tu-anon-key"

# Gemini Flash API Key (obtener en https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY="tu-gemini-api-key"
